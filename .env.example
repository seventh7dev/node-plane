BOT_TOKEN=replace_me
ADMIN_IDS=123456789

NODE_PLANE_BASE_DIR=/opt/node-plane
NODE_PLANE_APP_DIR=/opt/node-plane/current
NODE_PLANE_SHARED_DIR=/opt/node-plane/shared
NODE_PLANE_SOURCE_DIR=/opt/node-plane-src
NODE_PLANE_INSTALL_MODE=simple
NODE_PLANE_UPDATE_BRANCH=main
NODE_PLANE_INSTALL_REF=v0.1.2
NODE_PLANE_IMAGE_REPO=ghcr.io/seventh7dev/node-plane
NODE_PLANE_IMAGE_TAG=0.1.2
NODE_PLANE_PREVIOUS_IMAGE_TAG=
UPDATE_CHECK_INTERVAL_SECONDS=10800
UPDATE_CHECK_FIRST_DELAY_SECONDS=300
DB_BACKEND=postgres
POSTGRES_DSN=
# Legacy SQLite path is kept only as a migration source for pre-0.4 installs.
SQLITE_DB_PATH=/opt/node-plane/shared/data/bot.sqlite3
NODE_PLANE_POSTGRES_IMAGE=postgres:16-alpine
NODE_PLANE_POSTGRES_CONTAINER=node-plane-postgres
NODE_PLANE_POSTGRES_DB=node_plane
NODE_PLANE_POSTGRES_USER=node_plane
NODE_PLANE_POSTGRES_PASSWORD=
NODE_PLANE_POSTGRES_PORT=55432

SSH_KEY=/root/.ssh/id_ed25519
PROFILE_STATE_JSON_PATH=/opt/node-plane/shared/data/profile_state.json
TELEGRAM_USERS_JSON_PATH=/opt/node-plane/shared/data/telegram_users.json
AWG_JSON_PATH=/opt/node-plane/shared/data/awg.json
